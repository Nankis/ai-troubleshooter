{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Nankis/ai-troubleshooter/.workflow/task.schema.json",
  "title": "AI Troubleshooter Workflow Task",
  "type": "object",
  "required": ["id", "program", "title", "objective", "acceptance", "evidence_level"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^T-[0-9]{2,}$"
    },
    "program": {
      "type": "string",
      "pattern": "^P-[0-9]{4}-[0-9]{3}-.+"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "objective": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000
    },
    "inputs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "evidence_level": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"]
    },
    "verification_commands": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "requires_real_dependencies": {
      "type": "boolean",
      "default": false
    },
    "security_constraints": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "blocked", "completed"],
      "default": "pending"
    }
  }
}
